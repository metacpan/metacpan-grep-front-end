<!DOCTYPE html>
<html lang="en">
	<head>
		<meta charset="utf-8">
		<meta name="viewport" content="width=device-width, initial-scale=1">
<% IF search; THEN %>
		<title><% search | html %> results from the CPAN</title>
<% ELSIF title %>
		<title><% title %> - grep the CPAN</title>
<% ELSE %>
		<title>grep the CPAN — search Perl distributions with regex</title>
<% END %>
		<link rel="alternate" type="application/rss+xml" title="RSS" href="/feed/recent" />
		<link rel="search" href="/static/opensearch.xml" type="application/opensearchdescription+xml" title="MetaCPAN">
		<link rel="shortcut icon" href="/static/icons/favicon.ico">
		<link rel="apple-touch-icon" sizes="152x152" href="/static/icons/apple-touch-icon.png">

		<!-- Bootstrap 3 grid & base (CDN) -->
		<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@3.4.1/dist/css/bootstrap.min.css" integrity="sha384-HSMxcRTRxnN+Bdg0JdbxYKrThecOKuH5zCYotlSAcp1+c8xmyTe9GYg1l9a69psu" crossorigin="anonymous">

		<!-- Font Awesome 6 (CDN, replaces local FA4) -->
		<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@fortawesome/fontawesome-free@6.7.2/css/all.min.css" integrity="sha384-nRgPTkuX86pH8yjPJUAFuASXQSSl2/bBUiNV47vSYpKFxHJhbcrGnmlYpYJMeD7a" crossorigin="anonymous">

		<!-- Prism.js syntax highlighting (CDN, replaces SyntaxHighlighter) -->
		<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/prismjs@1.30.0/themes/prism.min.css" integrity="sha384-rCCjoCPCsizaAAYVoz1Q0CmCTvnctK0JkfCSjx7IIxexTBg+uCKtFYycedUjMyA2" crossorigin="anonymous">
		<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/prismjs@1.30.0/plugins/line-numbers/prism-line-numbers.min.css" integrity="sha384-nUkTNLI8COlMCRJ0FHIdX76If83145OTCLUx4gQyfnO0gGeO/sD9czGEUBxtkcUv" crossorigin="anonymous">
		<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/prismjs@1.30.0/plugins/line-highlight/prism-line-highlight.min.css" integrity="sha384-bCq+nBO5hUxeJTxGcpLbGAP5hqUhRUl9xclGVWMifyWonUxPS1+fO1JzOplEJsLP" crossorigin="anonymous">

		<!-- App styles -->
		<link rel="stylesheet" href="/css/grepcpan.css">

		<!-- App JS (no jQuery dependency) -->
		<script src="/javascripts/grepcpan.js" defer></script>

		<!-- Prism.js core + Perl language + plugins -->
		<script src="https://cdn.jsdelivr.net/npm/prismjs@1.30.0/prism.min.js" integrity="sha384-guvyurEPUUeAKyomgXWf/3v1dYx+etnMZ0CeHWsUXSqT1sRwh4iLpr9Z+Lw631fX" crossorigin="anonymous" defer></script>
		<script src="https://cdn.jsdelivr.net/npm/prismjs@1.30.0/components/prism-perl.min.js" integrity="sha384-TBezSCOvSMb3onoz0oj0Yi0trDW0ZQIz7CaneDU5q4gsUSqaPKMD6DlepFFJj+qa" crossorigin="anonymous" defer></script>
		<script src="https://cdn.jsdelivr.net/npm/prismjs@1.30.0/plugins/line-numbers/prism-line-numbers.min.js" integrity="sha384-6QJu8apxMmB9TiPVWzYKF5pRgKcz7snO0/QU+MrWmgBLECQjoa6erxX2VQ5t41Jd" crossorigin="anonymous" defer></script>
		<script src="https://cdn.jsdelivr.net/npm/prismjs@1.30.0/plugins/line-highlight/prism-line-highlight.min.js" integrity="sha384-aA5pbfEm+kZPOE/CKuBywvgtAzs4ZrQPlTwexPyFEwQ96E9rTPN1B0ObNmCn9tgH" crossorigin="anonymous" defer></script>
	</head>
	<body>
		<% INCLUDE main/_header.tt %>
		<div id="firstcontainer" class="container-fluid">
			<div class="row">
				<div class="main-content col-md-12" id="main-content">
					<% content %>
				</div>
			</div>
		</div>
		<div id="overlay" style="display:none;">
			<div class="home" style="text-align:center;">
				<a href="/" class="big-logo"></a>
			</div>
			<i class="fa-solid fa-arrows-rotate fa-spin fa-3x"></i>
			<span class="sr-only">Loading...</span>
			Grepping...
		</div>
	</body>
</html>
