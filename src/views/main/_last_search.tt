<% IF last_searches && last_searches.size %>
<div class="hidden-phone">
<li class="nav-header">Your recent searches</li>
<li>
  <div>
    <ul style="padding: 0px;">
      <% FOREACH search in last_searches %>
      <li><a href="/search?<% search.query_string | html_entity %>" title="<% search.display | html_entity %>"><% search.display | truncate(20, "...") | html_entity %></a>
      <% END %>
    </ul>
  </div>
</li>
</div>
<% END %>